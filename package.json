  "scripts": {
    "test": "pnpm exec playwright test",
    "test:headed": "CI=false PW_WORKERS=1 pnpm exec playwright test",
    "test:headed:slow": "CI=false PW_WORKERS=1 PW_SLOW_MO=300 pnpm exec playwright test",
    "test:headless": "CI=true PW_WORKERS=4 pnpm exec playwright test",
    "test:debug": "CI=false PW_WORKERS=1 pnpm exec playwright test --debug",
    "test:auth": "pnpm exec playwright test --grep @auth",
    "test:browsing": "pnpm exec playwright test --grep @browsing",
    "test:cart": "pnpm exec playwright test --grep @cart-checkout",
    "test:cookie": "pnpm exec playwright test --grep @cookie",
    "test:report": "pnpm exec playwright show-report --port 9324",
